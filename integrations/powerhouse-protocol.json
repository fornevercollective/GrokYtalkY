{
  "name": "GrokYtalkY powerhouse protocol",
  "version": "1.76.0",
  "hub": {
    "default": "ws://127.0.0.1:9876/",
    "env": "GY_HUB",
    "room_query": "room",
    "room_env": "GY_ROOM",
    "room_max_env": "GY_ROOM_MAX",
    "default_room": "global",
    "api": {
      "rooms": "GET /api/rooms",
      "peers": "GET /api/peers?room="
    }
  },
  "mesh_types": {
    "program": {
      "owner": "gy conductor (per room)",
      "fields": ["mode", "program", "preview", "caption", "caption_meta", "conductor", "seq", "room"],
      "consumers": ["gy venue", "gy TUI", "qbpm-gy-bridge", "blank multiview", "GrokGlyph", "sfu-bridge", "mid-lane"]
    },
    "mid-lane": {
      "owner": "gy mid-lane bridge",
      "note": "edge ingest envelope — program/hex only, never full HD",
      "fields": ["room", "lane", "program", "gyst", "caption", "mark", "seq"],
      "edge_env": ["GY_EDGE_URL", "GY_EDGE_TOKEN"],
      "reference_worker": "edge/mid-lane (CF DO fan-out)",
      "viewer": "site/mid-lane.html · WS /ws?room=",
      "ladder": ["glyph", "mid", "full"],
      "hd_env": ["GY_CALLS_WHIP_URL", "GY_CALLS_PLAYBACK_URL"]
    },
    "facility": {
      "ptp_env": ["GY_PTP_LOCKED", "GY_PTP_MODE", "GY_PTP_DOMAIN", "GY_PTP_OFFSET_NS", "GY_PTP_IFACE"],
      "nmos_env": ["GY_NMOS_REGISTRY", "GY_NMOS_POST", "GY_NMOS_HREF", "GY_NMOS_LABEL"],
      "doctor": "gy doctor nmos | sync | st2110"
    },
    "program-caption": {
      "owner": "chat-bridge --program-caption (opt-in)",
      "note": "caption-only merge; does not change PGM/PVW/mode; hub re-fans type:program",
      "fields": ["text", "caption", "caption_meta", "lang", "role", "speaker", "source"],
      "consumers": ["hub store", "venue OnANC via program"]
    },
    "caption": {
      "owner": "UI / chat-bridge --caption-event",
      "note": "informational only — no program bus authority",
      "consumers": ["gy TUI soft line", "GrokGlyph caption bar", "gy agent"]
    },
    "gyst": {
      "kinds": ["hexlum", "rgb24", "jpeg", "meta", "pcm16"],
      "forge": "cgf: marks + lattice on hexlum",
      "hexlum_lane": "vburst-frame.glyph promotes to gyst hexlum unless hex_lane skip",
      "consumers": ["dual Glyph", "gy agent", "sfu glyph/hex", "GrokGlyph RX"]
    },
    "vburst-frame": {
      "fields": ["glyph", "glyphN", "b64", "hex_lane"],
      "note": "walkie + optional hub hexlum promote"
    },
    "chat": {
      "consumers": ["gy TUI", "Space chat-bridge", "blank thread"]
    },
    "vision-take": {
      "owner": "gy Vision() pipeline",
      "note": "Grok/offline take + Aito side channels; may include MEDIA control-plane ops",
      "fields": ["feed", "theme", "caption", "style", "mute_hint", "segment_top", "segments", "pose", "pose_hands", "pose_joints", "depth", "media_ops", "provider", "latency_ms"],
      "consumers": ["site/livenews.html", "theme-vision plugin", "hub peers", "sfu-bridge optional"]
    },
    "news-caption": {
      "owner": "vision/orch apply",
      "fields": ["text", "theme", "feed", "source"],
      "consumers": ["site/livenews.html theme cluster"]
    }
  },
  "platform": {
    "contract": "integrations/grok-stream-platform.json",
    "doctor": "gy doctor platform · gy platform export",
    "docs": "docs/platform-integration.md"
  },
  "caption_meta": {
    "fields": ["text", "lang", "role", "speaker", "source"],
    "roles": ["lower", "upper", "crawl", "chyron", "speaker"],
    "sources": ["manual", "chat", "xl8", "bridge", "program"],
    "anc_udw": "plain UTF-8 or 0xC1+JSON rich (SDID 0x05)"
  },
  "anc": {
    "did": "0x5F",
    "sdid": {
      "0x01": "mark",
      "0x02": "tally",
      "0x03": "bus",
      "0x04": "preview",
      "0x05": "caption"
    },
    "capture": "program bus only (OnANC)"
  },
  "tools": {
    "overview": {
      "path": "~/dev/overview",
      "hook": "blank-tools-manifest.ts · category dojo"
    },
    "blank": {
      "path": "~/dev/blank",
      "hook": "stageforge.yaml · service gy when STAGEFORGE_GY=1"
    },
    "grok-cli": {
      "path": "~/dev/grok-cli-main",
      "hook": "scripts/powerhouse-stage.sh multi-stage"
    },
    "qbpm": {
      "path": "~/Projects/Qbpm",
      "hook": "static/gy-program-bridge.js · window.qbpmGy"
    },
    "grokglyph": {
      "path": "site/grokglyph.html",
      "hook": "PWA · cam/cast/hub · roster search · caption bar"
    },
    "livenews": {
      "path": "site/livenews.html",
      "hook": "vision-take segment_top · pose_hands · theme cluster"
    },
    "glyph-cast": {
      "path": "site/glyph-cast.html",
      "hook": "full-res LED cast (not auto-all-feeds)"
    }
  },
  "ports": {
    "gy_hub": 9876,
    "blank": 5173,
    "qbpm": 8796,
    "grok_notes": 3000,
    "sfu": 9880,
    "aito": 8766
  }
}
